# Meilisearch keys
MEILI_MASTER_KEY=aMasterKey
MEILI_SEARCH_API_KEY=aMasterKey
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres
# Internal Docker network settings for the backend container
DB_HOST=postgres
DB_PORT=5432


KITE_API_KEY=your api key
KITE_API_SECRET=your secret key
KITE_USER_ID=****
KITE_PASSWORD=*****
KITE_TOTP_KEY=******

# Refer ntfy docs for install and subcribe to a topic eg: scheduluer-alerts or scheduler, if its local hosting use http. notifications will work properly at this point.
SCHEDULER_NTFY_URL=https://ntfy.krishna.quest/scheduler-alerts
KITE_ALERTS_NTFY_URL=https://ntfy.krishna.quest/kite-alerts
MEILI_URL=http://meilisearch:7700
VITE_API_BASE_URL=http://localhost:18777

# App JWT auth (separate from broker auth)
APP_JWT_SECRET=change-me-to-a-long-random-secret
APP_JWT_ACCESS_MINUTES=15
APP_JWT_REFRESH_DAYS=14
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=change-me
# Preferred over APP_ADMIN_PASSWORD in production
# Format: pbkdf2_sha256$iterations$salt$hex_digest
APP_ADMIN_PASSWORD_HASH=
# Safer in Docker Compose because it avoids '$' interpolation. Base64 of APP_ADMIN_PASSWORD_HASH.
APP_ADMIN_PASSWORD_HASH_B64=
# Alternative: mount a secret file and point to it.
APP_ADMIN_PASSWORD_HASH_FILE=

# Host-exposed service ports (for local tools on your machine)
# Frontend:    http://localhost:15173
# Backend:     http://localhost:18777
# PostgreSQL:  localhost:15432
# Redis:       localhost:16379
# Meilisearch: http://localhost:17700
# MEILI_API_KEY is deprecated in favor of MEILI_SEARCH_API_KEY
# MEILI_API_KEY=aMasterKey
